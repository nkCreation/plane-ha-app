#!/command/with-contenv bashio
# ==============================================================================
# Initialize data directories and generate secrets
# ==============================================================================

bashio::log.info "Initializing Plane data directories..."

# Ensure persistent data dirs exist
mkdir -p /data/postgres /data/redis /data/rabbitmq /data/minio /data/plane/logs /data/plane/uploads /app/logs/access /app/logs/error /run/postgresql
chown -R postgres:postgres /data/postgres /run/postgresql

# Generate secrets if they don't exist yet
SECRETS_FILE="/data/plane/.secrets"
if [ ! -f "${SECRETS_FILE}" ]; then
    bashio::log.info "Generating secrets for first-time setup..."
    SECRET_KEY=$(openssl rand -hex 25)
    POSTGRES_PASSWORD=$(openssl rand -hex 16)
    RABBITMQ_PASSWORD=$(openssl rand -hex 16)
    MINIO_ROOT_PASSWORD=$(openssl rand -hex 16)

    cat > "${SECRETS_FILE}" <<EOF
SECRET_KEY=${SECRET_KEY}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
RABBITMQ_PASSWORD=${RABBITMQ_PASSWORD}
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
EOF
    chmod 600 "${SECRETS_FILE}"
    bashio::log.info "Secrets generated and stored."
fi

# Read config
DOMAIN_NAME=$(bashio::config 'domain_name')

# Source secrets
. "${SECRETS_FILE}"

# Write the full environment file used by all services
cat > /data/plane/.env <<EOF
# Domain
DOMAIN_NAME=${DOMAIN_NAME}
WEB_URL=http://${DOMAIN_NAME}
CORS_ALLOWED_ORIGINS=http://${DOMAIN_NAME},https://${DOMAIN_NAME}

# Django
SECRET_KEY=${SECRET_KEY}
DOCKERIZED=1
DEBUG=0

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DATABASE_URL=postgresql://plane:${POSTGRES_PASSWORD}@127.0.0.1:5432/plane

# Redis (Valkey)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=${RABBITMQ_PASSWORD}
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:${RABBITMQ_PASSWORD}@127.0.0.1:5672/plane

# MinIO (S3)
AWS_ACCESS_KEY_ID=plane
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9000
AWS_S3_BUCKET_NAME=uploads
AWS_REGION=us-east-1
MINIO_ROOT_USER=plane
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}

# File uploads
FILE_SIZE_LIMIT=5242880

# Ports
LISTEN_HTTP_PORT=7281
EOF

chmod 600 /data/plane/.env

bashio::log.info "Environment configured for domain: ${DOMAIN_NAME}"
